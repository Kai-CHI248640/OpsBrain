#!/usr/bin/env python3
"""Check web logs for login 500 error"""
import paramiko, sys

HOST = "129.211.28.47"
USER = "root"
PASSWORD = "***"

client = paramiko.SSHClient()
client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
client.connect(HOST, 22, USER, PASSWORD, timeout=20, allow_agent=False, look_for_keys=False)

# Check web logs
stdin, stdout, stderr = client.exec_command("docker logs opsbrain-web --tail 30 2>&1", timeout=15)
out = stdout.read().decode()
print("=== Web logs (last 30) ===")
print(out)
err = stderr.read().decode()
if err:
    print(f"ERR: {err}")

client.close()
