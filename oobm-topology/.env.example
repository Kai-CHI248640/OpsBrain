# ============================================================================
# OpsBrain OOBM — 环境变量配置模板
# ============================================================================
# 复制为 .env 并修改实际值
# cp .env.example .env
# ============================================================================

# ── 访问方式 ──────────────────────────────────────────────────────────────
# 部署后访问: http://SERVER_IP:OPSBRAIN_PORT/opsbrain/
OPSBRAIN_PORT=80

# ── 通用配置 ────────────────────────────────────────────────────────────────
OPSBRAIN_LOG_LEVEL=info            # debug | info | warning | error
OPSBRAIN_LOG_FORMAT=json           # json | text
OPSBRAIN_ROLE=collector            # collector | topology-builder

# ── JWT 密钥（生产环境必须修改） ───────────────────────────────────────────
OPSBRAIN_JWT_SECRET=change-me-in-production

# ── 设备清单 ────────────────────────────────────────────────────────────────
OPSBRAIN_INVENTORY_FILE=/etc/opsbrain/device-inventory.xlsx
OPSBRAIN_INVENTORY_OUTPUT=/var/lib/opsbrain/inventory/devices.json
OPSBRAIN_VALIDATE_STRICT=true

# ── 采集配置 ────────────────────────────────────────────────────────────────
OPSBRAIN_WORKERS=10                # 并行 Worker 数
OPSBRAIN_SSH_TIMEOUT=30            # SSH 连接超时（秒）
OPSBRAIN_SSH_RETRIES=2             # SSH 重试次数
OPSBRAIN_SSH_BACKOFF=exponential_jitter  # linear | exponential | exponential_jitter
OPSBRAIN_SSH_BANNER_TIMEOUT=10     # Banner 超时
OPSBRAIN_COMMAND_TIMEOUT=15        # 单条命令超时
OPSBRAIN_DEVICE_TIMEOUT=90         # 单台设备总超时
OPSBRAIN_ENABLE_TIMEOUT=10          # Enable 超时

# ── 发现配置 ────────────────────────────────────────────────────────────────
OPSBRAIN_MAX_ROUNDS=3              # 最大发现轮数
OPSBRAIN_AUTO_DISCOVER=true        # 自动发现新设备

# ── 输出配置 ────────────────────────────────────────────────────────────────
OPSBRAIN_OUTPUT_FORMATS=json,dot,mermaid
OPSBRAIN_RENDER_IMAGES=false

# ── 运行模式 ────────────────────────────────────────────────────────────────
OPSBRAIN_PIPELINE_MODE=full        # full | collect | topology | incremental

# ── 数据目录 ────────────────────────────────────────────────────────────────
OPSBRAIN_HOME=/var/lib/opsbrain
OPSBRAIN_CONFIG=/etc/opsbrain
OPSBRAIN_COLLECTED_DIR=/var/lib/opsbrain/collected
OPSBRAIN_PARSED_DIR=/var/lib/opsbrain/parsed
OPSBRAIN_OUTPUT_DIR=/var/lib/opsbrain/topology

# ── 模型 API ──────────────────────────────────────────────────────────────
# 提供商: openai | deepseek | siliconflow | anthropic | ollama | custom
OPSBRAIN_MODEL_PROVIDER=deepseek
OPSBRAIN_MODEL_API_BASE=
OPSBRAIN_MODEL_API_KEY=
OPSBRAIN_MODEL_MODEL=
OPSBRAIN_MODEL_MAX_TOKENS=4096
OPSBRAIN_MODEL_TEMPERATURE=0.3
OPSBRAIN_MODEL_TIMEOUT=60
OPSBRAIN_MODEL_MAX_RETRIES=3
OPSBRAIN_MODEL_ENABLED=false       # 默认关闭，需配置 API Key 后启用
OPSBRAIN_MODEL_PARSE_NEIGHBORS=true
OPSBRAIN_MODEL_DESCRIBE_TOPOLOGY=true
OPSBRAIN_MODEL_IDENTIFY_DEVICE=false

# ── 串口服务器地址（docker-compose extra_hosts 用） ────────────────────────
CONSOLE_SERVER_IP=10.0.0.100
